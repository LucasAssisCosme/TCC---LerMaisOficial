# ⚠️ IMPORTANTE: Copie este arquivo para .env e configure as variáveis
# cp .env.example .env

PORT=3000
APP_BASE_URL=http://localhost:3000
PUBLIC_API_BASE_URL=http://localhost:3000
CORS_ORIGIN=*

# ⚠️ GERE UMA CHAVE SEGURA - Nunca use a padrão em produção!
JWT_SECRET=gere_uma_chave_segura_aleatorea_aqui
JWT_EXPIRES_IN=24h

DEFAULT_BOOK_COVER_URL=https://gabrielchalita.com.br/wp-content/uploads/2019/12/semcapa.png
UPLOADS_ROOT_DIR=uploads
UPLOADS_ROUTE_PREFIX=uploads
PROFILE_UPLOAD_SUBDIR=perfis
BOOK_COVER_UPLOAD_SUBDIR=livro_capa

# ⚠️ CONFIGURE COM SUA SENHA DO BANCO DE DADOS
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sistema_leitura
DB_USER=root
DB_PASSWORD=sua_senha_segura_aqui
